{
  "bridge": {
    "url": "https://YOUR_DOMAIN.example/api/payment/event",
    "token_env": "WECHAT_RECEIVER_TOKEN",
    "timeout_seconds": 10,
    "user_agent": "Simple-WeChat-Payment-Receiver/1.0"
  },
  "agent": {
    "id": "linux-collector-01"
  },
  "channel": {
    "id": "7821",
    "provider": "wxpay"
  },
  "runtime": {
    "poll_seconds": 0.5,
    "spool_dir": "../spool/linux",
    "dedupe_file": "../spool/linux/receipt-dedupe.json",
    "max_retry_seconds": 300
  },
  "parser": {
    "timezone": "Asia/Shanghai",
    "max_event_age_seconds": 180,
    "max_future_seconds": 60,
    "include_raw_ocr_text": false,
    "receipt_pattern": "(?:经营码)?收款到账通知.{0,200}?(?P<month>\\d{1,2})月(?P<day>\\d{1,2})日(?P<hour>\\d{1,2}):(?P<minute>\\d{2}).{0,300}?(?:收款金额)?[￥¥YV]?(?P<amount>[0-9Oo]+[.．。][0-9Oo]{1,2})"
  },
  "linux": {
    "trigger_quiet_seconds": 0.8,
    "trigger_files": [
      "/home/YOUR_USER/xwechat_files/*/db_storage/message/biz_message_0.db-wal"
    ],
    "display": ":88",
    "window_name_regex": "^微信收款助手$",
    "window_probe": "xdotool",
    "capture_tool": "import",
    "ocr_tool": "tesseract",
    "ocr_language": "chi_sim+eng",
    "ocr_psm": 6,
    "window_width": 720,
    "window_height": 860,
    "window_x": 0,
    "window_y": 0,
    "scroll_down_clicks": 40,
    "capture_dir": "../captures/linux",
    "keep_screenshots": false,
    "capture_attempts": [
      {"delay_seconds": 2, "scroll_up_clicks": 0},
      {"delay_seconds": 5, "scroll_up_clicks": 2},
      {"delay_seconds": 9, "scroll_up_clicks": 4}
    ]
  }
}
