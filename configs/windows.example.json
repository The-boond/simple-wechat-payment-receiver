{
  "bridge": {
    "url": "https://YOUR_DOMAIN.example/api/payment/event",
    "token_env": "WECHAT_RECEIVER_TOKEN",
    "timeout_seconds": 10,
    "user_agent": "Simple-WeChat-Payment-Receiver/1.0"
  },
  "agent": {
    "id": "windows-collector-01"
  },
  "channel": {
    "id": "7821",
    "provider": "wxpay"
  },
  "runtime": {
    "poll_seconds": 0.5,
    "spool_dir": "../spool/windows",
    "dedupe_file": "../spool/windows/receipt-dedupe.json",
    "max_retry_seconds": 300
  },
  "parser": {
    "timezone": "Asia/Shanghai",
    "max_event_age_seconds": 180,
    "max_future_seconds": 60,
    "include_raw_ocr_text": false,
    "receipt_pattern": "(?:经营码)?收款到账通知.{0,200}?(?P<month>\\d{1,2})月(?P<day>\\d{1,2})日(?P<hour>\\d{1,2}):(?P<minute>\\d{2}).{0,300}?收款金额[￥¥YV]?(?P<amount>[0-9Oo]+[.．。][0-9Oo]{1,2})"
  },
  "windows": {
    "trigger_quiet_seconds": 0.8,
    "trigger_files": [
      "%USERPROFILE%\\Documents\\xwechat_files\\*\\db_storage\\message\\biz_message_0.db-wal",
      "D:\\xwechat_files\\*\\db_storage\\message\\biz_message_0.db-wal"
    ],
    "powershell": "powershell.exe",
    "ocr_script": "../scripts/windows/wechat_ocr.ps1",
    "process_names": ["Weixin", "WeChat"],
    "window_title_regex": "收款助手|微信|Weixin|WeChat",
    "include_notifications": false,
    "notification_app_regex": "微信|Weixin|WeChat",
    "allow_window_restore": false,
    "ocr_timeout_seconds": 30,
    "capture_attempts": [
      {"delay_seconds": 2, "request_restore": false},
      {"delay_seconds": 6, "request_restore": true},
      {"delay_seconds": 12, "request_restore": true}
    ]
  }
}
